# MongoDB
MONGODB_URI=mongodb://localhost:27017/salesforce_jira_sync
PORT=5000
NODE_ENV=development

# Demo Mode — set to true to run with seeded fake data (no real SF/JIRA needed)
DEMO_MODE=true

# Salesforce (not needed in demo mode)
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_USERNAME=demo@example.com
SALESFORCE_PASSWORD=demo_password
SALESFORCE_SECURITY_TOKEN=demo_token
SALESFORCE_CLIENT_ID=demo_client_id
SALESFORCE_CLIENT_SECRET=demo_client_secret

# JIRA (not needed in demo mode)
JIRA_BASE_URL=https://acme-corp.atlassian.net
JIRA_EMAIL=demo@example.com
JIRA_API_TOKEN=demo_api_token
JIRA_PROJECT_KEY=PROJ

# Sync
SYNC_INTERVAL_MINUTES=5
SYNC_BATCH_SIZE=50

# JWT
JWT_SECRET=demo_jwt_secret_change_in_production

# Frontend
FRONTEND_URL=http://localhost:3000
